local RunService=game:GetService("RunService")
local Rayfield=if RunService:IsStudio() then require(game.ReplicatedStorage.Packages.Rayfield.main) else loadstring(game:HttpGet('http://raw.githubusercontent.com/PaazlisMaswa/RobloxProject/refs/heads/main/Packages/Rayfield/init.luau'))()

local Window=Rayfield:CreateWindow({
	Name="Rayfield",
})

local Tab=Window:CreateTab("Main")
warn("Tab:",Tab)

local Divider=Tab:CreateDivider()
warn("Divider:",Divider)

local Select=Tab:CreateSelect({
	Callback=function(Target)
		print("Select:",Target)
	end,
})
warn("Select:",Select)

local Button=Tab:CreateButton({
	Name="Button Example",
	Callback=function()
		print("Kick")
	end,
})
warn("Button:",Button)

local Dropdown=Tab:CreateDropdown({
	Name="Dropdown Example",
	CurrentOption={"Option1","Option2","Option3"},
	CurrentValue="Option1",
	MultipleOptions=false,
	Callback=function(Value)
		print("Dropdown:",Value)
	end,
})
warn("Dropdown:",Dropdown)

local MultiDropdown=Tab:CreateDropdown({
	Name="Dropdown Example",
	CurrentOption={"Option1","Option2","Option3"},
	CurrentValue={"Option1"},
	MultipleOptions=true,
	Callback=function(Value)
		print("Multi Dropdown:",Value)
	end,
})
warn("Multi Dropdown:",MultiDropdown)

local Input=Tab:CreateInput({
	Callback=function(Value)
		print("Input:",Value)
	end,
})
warn("Input:",Input)

local Label=Tab:CreateLabel()
warn("Label:",Label)

local Paragraph=Tab:CreateParagraph()
warn("Paragraph:",Paragraph)

local ColorPicker=Tab:CreateColorPicker({
	
})
warn("ColorPicker:",ColorPicker)

local Slider=Tab:CreateSlider({
	Version=1,
	CurrentValue=10,
	-- If you use this, Range is removed and replaced with Percent. 
	-- This has an impact on CurrentValue
	Percent = 25, 
	Range={10,100},
	Increment=1,
	Callback = function(Value)
		print("Slider:",Value)
	end
})
warn("Slider:",Slider)

Rayfield:LoadConfiguration()
