local function UpdateHumanoid(char)
	local humanoid=char:FindFirstChildOfClass("Humanoid")
	if humanoid then
		SavedWalkSpeed=humanoid.WalkSpeed
		SliderPro:Refresh(SavedWalkSpeed)
	end
end

